# Production environment for SiamTeX
# Install: sudo install -m 640 -o root -g www-data config/siamtex.env.example /etc/siamtex.env
# Then edit /etc/siamtex.env with your values.

# --- Required for OAuth (optional for solo/local mode) ---

# Public base URL (no trailing slash)
SIAMTEX_OAUTH_BASE_URL=https://YOUR_HOST/siamtex

# GitHub OAuth App — https://github.com/settings/developers
# Authorization callback URL:
#   https://YOUR_HOST/siamtex/api/auth_callback.php
SIAMTEX_GITHUB_CLIENT_ID=
SIAMTEX_GITHUB_CLIENT_SECRET=

# 1 = require sign-in when OAuth is configured; 0 = allow anonymous local user
SIAMTEX_AUTH_REQUIRED=1

# --- Secrets (recommended in production — auto-generated in data/ if unset) ---

# 64 hex chars or base64-encoded 32-byte key
# SIAMTEX_SESSION_SECRET=
# SIAMTEX_MASTER_KEY=

# --- Compile worker ---

SIAMTEX_DOCKER_IMAGE=siamtex-tex-worker:local
# SIAMTEX_DOCKER_BIN=/usr/bin/docker
# SIAMTEX_COMPILE_MEMORY=512m
# SIAMTEX_COMPILE_TIMEOUT=60

# --- Limits ---

# SIAMTEX_MAX_UPLOAD_BYTES=5242880
# SIAMTEX_ARTIFACT_RETENTION_DAYS=7
# SIAMTEX_SOFT_DELETE_DAYS=30
# SIAMTEX_SESSION_LIFETIME_DAYS=30

# --- Debug ---

# SIAMTEX_DEBUG=0
