# Production environment for SiamTeX
# Install: sudo install -m 640 -o root -g www-data config/siamtex.env.example /etc/siamtex.env
# Then edit /etc/siamtex.env with your values.

# --- Required for OAuth (optional for solo/local mode) ---

# Public base URL (no trailing slash)
SIAMTEX_OAUTH_BASE_URL=https://YOUR_HOST/siamtex

# GitHub OAuth App — https://github.com/settings/developers
# Authorization callback URL:
#   https://YOUR_HOST/siamtex/api/auth_callback.php
SIAMTEX_GITHUB_CLIENT_ID=
SIAMTEX_GITHUB_CLIENT_SECRET=

# 1 = require sign-in when OAuth is configured; 0 = allow anonymous local user
SIAMTEX_AUTH_REQUIRED=1

# --- Secrets (recommended in production — auto-generated in data/ if unset) ---

# 64 hex chars or base64-encoded 32-byte key
# SIAMTEX_SESSION_SECRET=
# SIAMTEX_MASTER_KEY=

# --- Compile worker ---

SIAMTEX_DOCKER_IMAGE=siamtex-tex-worker:local
# SIAMTEX_DOCKER_BIN=/usr/bin/docker
# SIAMTEX_COMPILE_MEMORY=512m
# SIAMTEX_COMPILE_TIMEOUT=60

# --- Limits ---

# SIAMTEX_MAX_UPLOAD_BYTES=5242880
# SIAMTEX_ARTIFACT_RETENTION_DAYS=7
# SIAMTEX_SOFT_DELETE_DAYS=30
# SIAMTEX_SESSION_LIFETIME_DAYS=30

# --- Debug ---

# SIAMTEX_DEBUG=0

# --- AI (optional, alpha/experimental — quality depends on model; see docs/ai-providers.md) ---

# SIAMTEX_AI_ENABLED=1
# SIAMTEX_AI_MAX_TOKENS=16384
# SIAMTEX_AI_TIMEOUT=180
# SIAMTEX_AI_MAX_CALLS_PER_HOUR=20
# SIAMTEX_AI_MAX_CONTEXT_CHARS=200000

# --- Ollama (self-hosted / Tailscale home GPU) ---
# SIAMTEX_AI_PROVIDER=ollama
# SIAMTEX_AI_BASE_URL=http://home-ollama:11434/v1
# SIAMTEX_AI_MODEL=qwythos:9b

# --- OpenAI ---
# SIAMTEX_AI_PROVIDER=openai
# SIAMTEX_AI_BASE_URL=https://api.openai.com/v1
# SIAMTEX_AI_MODEL=gpt-4.1-mini
# SIAMTEX_AI_API_KEY=sk-...

# --- Google Gemini (OpenAI-compatible endpoint) ---
# SIAMTEX_AI_PROVIDER=google
# SIAMTEX_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# SIAMTEX_AI_MODEL=gemini-2.0-flash
# SIAMTEX_AI_API_KEY=

# --- xAI Grok ---
# SIAMTEX_AI_PROVIDER=xai
# SIAMTEX_AI_BASE_URL=https://api.x.ai/v1
# SIAMTEX_AI_MODEL=grok-3-mini
# SIAMTEX_AI_API_KEY=xai-...

# --- OpenRouter (Claude, Llama, many models — use for Anthropic/Claude) ---
# SIAMTEX_AI_PROVIDER=openrouter
# SIAMTEX_AI_BASE_URL=https://openrouter.ai/api/v1
# SIAMTEX_AI_MODEL=anthropic/claude-3.5-haiku
# SIAMTEX_AI_API_KEY=sk-or-...

# --- Other OpenAI-compatible (Groq, Together, LiteLLM, …) ---
# SIAMTEX_AI_PROVIDER=openai_compatible
# SIAMTEX_AI_BASE_URL=https://api.groq.com/openai/v1
# SIAMTEX_AI_MODEL=llama-3.3-70b-versatile
# SIAMTEX_AI_API_KEY=

# Per-file version history retention (branching undo tree; default 150)
# SIAMTEX_MAX_FILE_REVISIONS=150
