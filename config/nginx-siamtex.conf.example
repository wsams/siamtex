# Nginx — sample server block for SiamTeX + PHP-FPM
# Adjust root, server_name, and fastcgi_pass socket for your system.

server {
    listen 443 ssl http2;
    server_name YOUR_HOST;

    root /var/www/html/siamtex;
    index index.php;

    # ssl_certificate     /etc/letsencrypt/live/YOUR_HOST/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/YOUR_HOST/privkey.pem;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ ^/(data|vendor|work|config|scripts|docker|docs|src|templates|\.git|\.cursor) {
        deny all;
        return 404;
    }

    location ~ /\. {
        deny all;
    }

    location ~* \.(md|example|env|sqlite|key|enc)$ {
        deny all;
    }

    location ~ ^/composer\.(json|lock)$ {
        deny all;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
        fastcgi_read_timeout 120s;
    }

    # AI streaming — disable buffering so SSE tokens reach the browser promptly.
    # Matches /api/ai_stream.php (app at vhost root) or /siamtex/api/ai_stream.php (subpath).
    # Raise fastcgi_read_timeout if SIAMTEX_AI_TIMEOUT is higher than 180.
    location ~ /api/ai_stream\.php$ {
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
        fastcgi_buffering off;
        fastcgi_read_timeout 180s;
    }

    access_log /var/log/nginx/siamtex-access.log;
    error_log  /var/log/nginx/siamtex-error.log;
}

