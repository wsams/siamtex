# Apache 2.4 — sample virtual host for SiamTeX
# Adjust DocumentRoot, ServerName, and TLS paths for your deployment.

<VirtualHost *:443>
    ServerName YOUR_HOST
    DocumentRoot /var/www/html/siamtex

    SSLEngine on
    # SSLCertificateFile /etc/letsencrypt/live/YOUR_HOST/fullchain.pem
    # SSLCertificateKeyFile /etc/letsencrypt/live/YOUR_HOST/privkey.pem

    <Directory /var/www/html/siamtex>
        Options -Indexes +FollowSymLinks
        # Allow .htaccess rules (copy config/htaccess.example → .htaccess)
        AllowOverride FileInfo Options AuthConfig
        Require all granted
    </Directory>

    # Block non-public paths (see AGENTS.md — web surface vs repo)
    <DirectoryMatch "^/var/www/html/siamtex/(data|vendor|work|config|scripts|docker|docs|src|templates|\.git|\.cursor)">
        Require all denied
    </DirectoryMatch>

    <FilesMatch "\.(md|example|env|sqlite|key|enc)$">
        Require all denied
    </FilesMatch>

    <FilesMatch "^\.">
        Require all denied
    </FilesMatch>

    <FilesMatch "^composer\.(json|lock)$">
        Require all denied
    </FilesMatch>

    ErrorLog ${APACHE_LOG_DIR}/siamtex-error.log
    CustomLog ${APACHE_LOG_DIR}/siamtex-access.log combined
</VirtualHost>

# Redirect HTTP to HTTPS (optional)
# <VirtualHost *:80>
#     ServerName YOUR_HOST
#     Redirect permanent / https://YOUR_HOST/
# </VirtualHost>
