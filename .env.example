# Copy to a secure path outside the web tree, e.g. /etc/siamtex.env
# See config/README.md for Apache/Nginx and php-fpm wiring.

# Public URL where SiamTeX is installed (no trailing slash)
SIAMTEX_OAUTH_BASE_URL=https://YOUR_HOST/siamtex

# GitHub OAuth App (optional — omit both to run in local solo mode)
# Callback URL: https://YOUR_HOST/siamtex/api/auth_callback.php
SIAMTEX_GITHUB_CLIENT_ID=
SIAMTEX_GITHUB_CLIENT_SECRET=
SIAMTEX_AUTH_REQUIRED=1

# Optional tuning
# SIAMTEX_DEBUG=0
# SIAMTEX_SESSION_SECRET=
# SIAMTEX_MASTER_KEY=
# SIAMTEX_DOCKER_IMAGE=siamtex-tex-worker:local
# SIAMTEX_DOCKER_BIN=/usr/bin/docker
# SIAMTEX_COMPILE_MEMORY=512m
# SIAMTEX_COMPILE_TIMEOUT=60
# SIAMTEX_MAX_UPLOAD_BYTES=5242880
